name: Daily AI Run

on:
  schedule:
    - cron: "0 18 * * *"

jobs:
  run:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v3

      - name: Setup Python
        uses: actions/setup-python@v4
        with:
          python-version: 3.11

      - name: Install
        run: pip install -r requirements.txt

      - name: Run pipeline
        run: python run.py
